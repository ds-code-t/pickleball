{
  "remoteUrl": "https://ondemand.us-west-1.saucelabs.com/wd/hub",
  "browserName": "chrome",
  "browserVersion": "latest",
  "platformName": "Windows 11",
  "acceptInsecureCerts": true,
  "pageLoadStrategy": "normal",
  "timeouts": {
    "implicit": 0,
    "pageLoad": 300000,
    "script": 30000
  },
  "goog:chromeOptions": {
    "args": [
      "--disable-print-preview",
      "--test-type",
      "--ignore-certificate-errors",
      "--ignore-certificate-errors-spki-list=",
      "--allow-insecure-localhost"
    ]
  },
  "sauce:options": {
    "username": "~<$resolveVar:SAUCE_USERNAME>~",
    "accessKey": "~<$resolveVar:pkb_SAUCE_ACCESS_KEY>~",
    "name": "Chrome Sauce Test",
    "build": "local-dev-build"
  }
}